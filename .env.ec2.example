# EC2 Environment Configuration
# Copy this file to .env on your EC2 instance

# ============================================
# JWT Configuration (REQUIRED)
# ============================================
# IMPORTANT: This must match your production JWT secret from Elastic Beanstalk
# Otherwise, existing user tokens won't work
JWT_SECRET=your-production-jwt-secret-here-at-least-64-characters-long

# ============================================
# MongoDB Atlas (Already configured in docker-compose.ec2.yml)
# ============================================
# You don't need to set this here - it's already in docker-compose.ec2.yml
# Connection String: mongodb+srv://dev_divisha_app:Divisha%40123@cluster0.btsspaw.mongodb.net/crm_prod

# ============================================
# Application URLs
# ============================================
# Update these after DNS switch
FRONTEND_URL=https://crm.ascendons.com
BACKEND_URL=https://api.ascendons.com

# During testing phase, you can also use:
# FRONTEND_URL=http://<EC2-ELASTIC-IP>
# BACKEND_URL=http://<EC2-ELASTIC-IP>

# ============================================
# Optional: CORS Configuration
# ============================================
# Already set in docker-compose.ec2.yml
# CORS_ALLOWED_ORIGINS=https://crm.ascendons.com,http://localhost:3000

# ============================================
# Optional: Logging
# ============================================
# LOG_LEVEL=INFO

# ============================================
# NOTES
# ============================================
# 1. JWT_SECRET is the only critical variable you MUST set
# 2. MongoDB connection is already configured in docker-compose.ec2.yml
# 3. URLs will be used after DNS switch
# 4. Make sure to keep this file secure (it's in .gitignore)
